<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
          xmlns:cpi="urn:schemas-microsoft-com:cpi">

  <!-- Windows Setup phase -->
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/INDEX</Key>
              <Value>1</Value> <!-- your custom WIM -->
            </MetaData>
          </InstallFrom>
          <!-- no InstallTo / no InstallToAvailablePartition -->
        </OSImage>
      </ImageInstall>
      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>SCOS</FullName>
        <Organization>SteamConsole</Organization>
        <ProductKey><Key>VK7JG-NPHTM-C97JM-9MPGT-3V66T</Key></ProductKey>
      </UserData>
    </component>

    <component name="Microsoft-Windows-International-Core-WinPE" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>
  </settings>

  <!-- Specialize phase -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <TimeZone>Romance Standard Time</TimeZone>

      <!-- Temporary Windows setup name.
           SCOSSetupProgress.ps1 v0.3.6.4 renames the console to SCOS-XXXXXX before final reboot. -->
      <ComputerName>*</ComputerName>
    </component>
  </settings>

  <!-- OOBE phase -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Password>
              <!-- Temporary bootstrap setup password only.
                   SCOS v0.3.6.4 replaces it with a unique generated password during final setup.
                   SCOS Builder should replace this placeholder before building the ISO. -->
              <Value>__SCOS_BOOTSTRAP_PASSWORD__</Value>
              <PlainText>true</PlainText>
            </Password>
            <Description>Console user</Description>
            <DisplayName>SCOS</DisplayName>
            <Group>Administrators</Group>
            <Name>SCOS</Name>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Domain>.</Domain>
        <Username>SCOS</Username>
        <Password>
          <!-- Temporary bootstrap setup password only.
               SCOS v0.3.6.4 updates AutoAdminLogon with the generated per-install password.
               This value must match the LocalAccount password above. -->
          <Value>__SCOS_BOOTSTRAP_PASSWORD__</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>999</LogonCount>
      </AutoLogon>
    </component>
  </settings>

  <cpi:offlineImage cpi:source="wim://install.wim/1"/>
</unattend>
